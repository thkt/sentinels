{
  "description": "Auto-format files after Write/Edit/MultiEdit",
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Write|Edit|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/hooks/wrapper.sh formatter",
            "timeout": 2000
          }
        ]
      }
    ]
  }
}
