{
  "description": "Parallel quality gates - validates codebase on Write/Edit/MultiEdit",
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Write|Edit|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/hooks/wrapper.sh gates",
            "timeout": 70000
          }
        ]
      }
    ]
  }
}
